# Server Environment Variables
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Firebase Admin SDK ────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → save the JSON file
# 3. Run this PowerShell command to encode it:
#    [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("C:\path\to\serviceAccount.json")) | Set-Content "server\encoded.txt"
# 4. Paste the result below (no quotes)
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json_here
